# synsc-context engine
SYNSC_API_URL=http://localhost:8742
SYNSC_API_KEY=

# Nia engine
NIA_API_URL=https://apigcp.trynia.ai
NIA_API_KEY=

# Context7 engine
CONTEXT7_ENABLED=true
CONTEXT7_NPX_COMMAND=npx
CONTEXT7_REQUEST_DELAY=0.5
CONTEXT7_API_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Multi-model matrix (used with --multi-model flag)
# Set API key per provider + optional model overrides per tier
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# --- Gemini ---
BENCH_GEMINI_API_KEY=
BENCH_GEMINI_LOW_MODEL=gemini-2.5-flash-lite
BENCH_GEMINI_MID_MODEL=gemini-2.5-flash
BENCH_GEMINI_HIGH_MODEL=gemini-2.5-pro

# --- Anthropic ---
BENCH_ANTHROPIC_API_KEY=
BENCH_ANTHROPIC_LOW_MODEL=claude-haiku-4-5-20251001
BENCH_ANTHROPIC_MID_MODEL=claude-sonnet-4-6
BENCH_ANTHROPIC_HIGH_MODEL=claude-opus-4-6

# --- OpenAI ---
BENCH_OPENAI_API_KEY=
BENCH_OPENAI_LOW_MODEL=gpt-5-nano-2025-08-07
BENCH_OPENAI_MID_MODEL=gpt-5-2025-08-07
BENCH_OPENAI_HIGH_MODEL=o3

# --- LLM Judge (legacy single-model, used when --multi-model is not set) ---
BENCH_LLM_PROVIDER=anthropic
BENCH_LLM_MODEL=claude-sonnet-4-6
BENCH_LLM_API_KEY=
